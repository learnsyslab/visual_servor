<?xml version="1.0" encoding="utf-8"?>
<robot name="tray_pendulum" xmlns:xacro="http://wiki.ros.org/xacro">
  <link name="tray_pendulum">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.3"/>
      <geometry>
        <cylinder radius="0.18" length="0.01"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.3"/>
      <geometry>
        <cylinder radius="0.18" length="0.01"/>
      </geometry>
      </collision>
     <inertial>
       <mass value="1"/>
       <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
       <origin rpy="0 0 0" xyz="0 0 0.3"/>
     </inertial>
     </link>

   <link name="dummy1"></link>
   <link name="dummy2"></link>

   <joint name="pendulum_x_joint" type="continuous">
     <axis xyz="1 0 0"/>
     <origin rpy="1.571 0 0.2617993877991494" xyz="0 0 0"/>
     <parent link="ur10_arm_tool0"/>
     <child link="dummy1"/>
  </joint>

  <joint name="pendulum_y_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="dummy1"/>
    <child link="dummy2"/>
  </joint>

  <joint name="pendulum_z_joint" type="continuous">
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="dummy2"/>
    <child link="tray_pendulum"/>
  </joint>

  <!-- <joint name="pendulum_ball_joint" type="spherical"> -->
  <!--   <origin rpy="1.571 0 0.2617993877991494" xyz="0 0 0"/> -->
  <!--   <parent link="ur10_arm_tool0"/> -->
  <!--   <child link="tray_pendulum"/> -->
  <!-- </joint> -->

</robot>
